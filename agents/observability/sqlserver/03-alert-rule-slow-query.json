{
  "title": "SQL Server - Query Lenta Critica",
  "ruleGroup": "sql-server-alerts",
  "folderUID": "sql-server-alerts",
  "noDataState": "NoData",
  "execErrState": "Error",
  "for": "0s",
  "annotations": {
    "summary": "Query lenta detectada no SQL Server",
    "description": "Uma query esta com tempo medio de execucao de {{ $value }}ms (threshold: 35000ms / 35s). Verifique o dashboard SQL Server Performance Monitor.",
    "runbook_url": "",
    "dashboardUid": "sqlserver-perf",
    "panelId": "6"
  },
  "labels": {
    "severity": "critical",
    "team": "dba",
    "source": "sql-server"
  },
  "data": [
    {
      "refId": "A",
      "relativeTimeRange": {
        "from": 60,
        "to": 0
      },
      "datasourceUid": "__SUBSTITUIR_PELO_UID_DO_DATASOURCE__",
      "model": {
        "editorMode": "code",
        "format": "table",
        "rawQuery": true,
        "rawSql": "SELECT MAX((qs.total_elapsed_time / qs.execution_count) / 1000) AS max_avg_elapsed_time_ms\nFROM sys.dm_exec_query_stats qs\nWHERE qs.execution_count > 0",
        "refId": "A"
      }
    },
    {
      "refId": "B",
      "relativeTimeRange": {
        "from": 60,
        "to": 0
      },
      "datasourceUid": "-100",
      "model": {
        "conditions": [
          {
            "evaluator": {
              "params": [35000],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": ["A"]
            },
            "reducer": {
              "params": [],
              "type": "last"
            },
            "type": "query"
          }
        ],
        "datasource": {
          "type": "__expr__",
          "uid": "-100"
        },
        "expression": "A",
        "type": "threshold",
        "refId": "B"
      }
    }
  ]
}
